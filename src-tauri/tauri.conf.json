{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Incuboot",
  "version": "0.1.0",
  "identifier": "com.alpha-studio.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Incuboot",
        "width": 1360,
        "height": 860,
        "minWidth": 1060,
        "minHeight": 680,
        "resizable": true,
        "maximizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "center": true,
        "visible": true,
        "focus": true,
        "shadow": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "category": "Business",
    "shortDescription": "Incuboot - private vertical commercial brand intelligence workspace",
    "longDescription": "Incuboot organizes brand directories, conversations, assets, and strategy work in a private vertical commercial desktop UI.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
